            "keyVaultName": "[format('kv-{0}-{1}', parameters('baseName'), variables('uniqueSuffix'))]",
            "privateEndpointName": "[format('pe-kv-{0}', parameters('baseName'))]",
            "privateDnsZoneName": "privatelink.vaultcore.azure.net"
          },
          "resources": [
            {
              "type": "Microsoft.KeyVault/vaults",
