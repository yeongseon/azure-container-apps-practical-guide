              "name": "[format('{0}/{1}', variables('privateDnsZoneName'), format('link-{0}', parameters('baseName')))]",
              "location": "global",
              "properties": {
                "registrationEnabled": false,
                "virtualNetwork": {
                  "id": "[parameters('vnetId')]"
